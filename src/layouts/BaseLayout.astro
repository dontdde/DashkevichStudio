---
import { site } from '../data/site';
import TelegramIcon from '../components/TelegramIcon.astro';
import InstagramIcon from '../components/InstagramIcon.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import CookieNotice from '../components/CookieNotice.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import { commonCopy, localePath, type Locale } from '../i18n';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  path?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
  locale?: Locale;
  robots?: string;
}

const { title, description = site.description, path = '/', schema, locale = 'ru', robots = 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1' } = Astro.props;
const copy = commonCopy[locale];
const canonical = new URL(path, site.url).toString();
const pageTitle = title.includes(site.name) ? title : `${title} | ${site.name}`;
const navPaths = ['/', '/development/', '/ai-agents/', '/cases/'];
const routeWithoutLocale = path.replace(/^\/(en|ru|pl)(?=\/|$)/, '') || '/';
const ogLocale = { en: 'en_US', ru: 'ru_BY', pl: 'pl_PL' }[locale];
const alternateOgLocales = Object.values({ en: 'en_US', ru: 'ru_BY', pl: 'pl_PL' }).filter((value) => value !== ogLocale);
const pageSchemas = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
const breadcrumbName = { en: 'Home', ru: 'Главная', pl: 'Strona główna' }[locale];
const breadcrumbSchema = path === localePath(locale, '/') ? [] : [{
  '@type': 'BreadcrumbList',
  '@id': `${canonical}#breadcrumb`,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: breadcrumbName, item: new URL(localePath(locale, '/'), site.url).toString() },
    { '@type': 'ListItem', position: 2, name: title, item: canonical }
  ]
}];
const schemaGraph = [
  {
    '@type': 'Organization',
    '@id': `${site.url}/#organization`,
    name: site.name,
    legalName: site.legalName,
    alternateName: site.alternateNames,
    url: site.url,
    logo: { '@type': 'ImageObject', url: new URL('/logo-512.png', site.url).toString(), width: 512, height: 512 },
    email: site.email,
    telephone: site.phoneLabel,
    taxID: site.taxId,
    sameAs: [site.telegramUrl, site.instagramUrl],
    founder: { '@type': 'Person', name: site.legalName }
  },
  {
    '@type': 'WebSite',
    '@id': `${site.url}/#website`,
    name: site.name,
    alternateName: site.alternateNames,
    url: site.url,
    inLanguage: ['en', 'ru', 'pl'],
    publisher: { '@id': `${site.url}/#organization` }
  },
  {
    '@type': 'WebPage',
    '@id': `${canonical}#webpage`,
    name: pageTitle,
    description,
    url: canonical,
    inLanguage: locale,
    isPartOf: { '@id': `${site.url}/#website` },
    about: { '@id': `${site.url}/#organization` }
  },
  ...breadcrumbSchema,
  ...pageSchemas.map((entry) => {
    const { ['@context']: _context, ...value } = entry;
    return value;
  })
];
const structuredData = { '@context': 'https://schema.org', '@graph': schemaGraph };
---

<!doctype html>
<html lang={locale} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      (() => {
        try {
          const theme = localStorage.getItem('dashkevich-theme');
          document.documentElement.dataset.theme = theme === 'light' ? 'light' : 'dark';
        } catch {
          document.documentElement.dataset.theme = 'dark';
        }
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="dark light" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={new URL(localePath('en', routeWithoutLocale), site.url)} />
    <link rel="alternate" hreflang="ru" href={new URL(localePath('ru', routeWithoutLocale), site.url)} />
    <link rel="alternate" hreflang="pl" href={new URL(localePath('pl', routeWithoutLocale), site.url)} />
    <link rel="alternate" hreflang="x-default" href={new URL(localePath('ru', routeWithoutLocale), site.url)} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-48x48.png" type="image/png" sizes="48x48" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#18c98b" />
    <meta name="robots" content={robots} />
    <meta name="author" content={site.name} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content={ogLocale} />
    {alternateOgLocales.map((value) => <meta property="og:locale:alternate" content={value} />)}
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL('/logo-512.png', site.url)} />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta property="og:image:alt" content="Dashkevich Studio" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/logo-512.png', site.url)} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <a class="skip-link" href="#content">{copy.skip}</a>
    <header class="site-header">
      <a class="brand" href={localePath(locale, '/')} aria-label="Dashkevich Studio">
        <span class="brand-mark">D</span>
        <span>Dashkevich Studio</span>
      </a>
      <nav class="main-nav" aria-label={copy.navLabel}>
        {navPaths.map((href, index) => <a href={localePath(locale, href)}>{copy.nav[index]}</a>)}
      </nav>
      <div class="header-actions">
        <div class="preference-controls">
          <LanguageSwitcher locale={locale} pathname={Astro.url.pathname} />
          <ThemeToggle locale={locale} />
        </div>
        <div class="header-contacts" aria-label={copy.contacts}>
          <a class="phone-link" href={site.phoneHref}>{site.phoneLabel}</a>
          <TelegramIcon ariaLabel={copy.telegram} />
          <InstagramIcon ariaLabel={copy.instagram} />
          <a class="email-link" href={`mailto:${site.email}`}>{site.email}</a>
        </div>
      </div>
    </header>
    <main id="content">
      <slot />
    </main>
    <footer class="site-footer">
      <div>
        <strong>{site.name}</strong>
        <p>{copy.footer}</p>
      </div>
      <div class="footer-links">
        <TelegramIcon ariaLabel={copy.telegram} />
        <InstagramIcon ariaLabel={copy.instagram} />
        <a href={`mailto:${site.email}`}>{site.email}</a>
        <a href={site.phoneHref}>{site.phoneLabel}</a>
      </div>
      <nav class="legal-links" aria-label={copy.legalLabel}>
        <a href={localePath(locale, '/privacy/')}>{copy.privacy}</a>
        <a href={localePath(locale, '/offer/')}>{copy.offer}</a>
        <a href={localePath(locale, '/requisites/')}>{copy.requisites}</a>
      </nav>
    </footer>
    <CookieNotice locale={locale} />
    <script define:vars={{ themeDark: copy.themeDark, themeLight: copy.themeLight, toDark: copy.toDark, toLight: copy.toLight }}>
      const syncThemeToggle = () => {
        const isLight = document.documentElement.dataset.theme === 'light';
        document.querySelectorAll('[data-theme-toggle]').forEach((button) => {
          button.setAttribute('aria-pressed', String(isLight));
          button.setAttribute('aria-label', isLight ? toDark : toLight);
        });
        document.querySelectorAll('[data-theme-toggle-text]').forEach((label) => {
          label.textContent = isLight ? themeLight : themeDark;
        });
      };

      document.querySelectorAll('[data-theme-toggle]').forEach((button) => {
        button.addEventListener('click', () => {
          const nextTheme = document.documentElement.dataset.theme === 'light' ? 'dark' : 'light';
          document.documentElement.dataset.theme = nextTheme;
          try {
            localStorage.setItem('dashkevich-theme', nextTheme);
          } catch {}
          syncThemeToggle();
        });
      });

      syncThemeToggle();

      document.querySelectorAll('a, button').forEach((element) => {
        element.addEventListener('click', () => {
          element.classList.remove('is-tapped');
          window.requestAnimationFrame(() => {
            element.classList.add('is-tapped');
            window.setTimeout(() => element.classList.remove('is-tapped'), 420);
          });
        });
      });
    </script>
  </body>
</html>

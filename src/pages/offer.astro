---
import BaseLayout from '../layouts/BaseLayout.astro';import {site} from '../data/site';import {localePath,type Locale} from '../i18n';
interface Props{locale?:Locale} const{locale='en'}=Astro.props;
const c={en:{title:'Public offer',description:'Dashkevich Studio public offer for development and automation services.',label:'Document',note:'Draft. Terms, pricing, delivery schedule, payment and company details must match the actual engagement model.',sections:[['1. Scope','The provider delivers websites, web services, integrations, Telegram bots, automation and AI tools.'],['2. Process','Scope, timing, price and stages are agreed in writing, in a contract, invoice or appendix.'],['3. Payment','Payment follows the agreed terms. This section is a general template until online payment is introduced.'],['4. Deliverables','Deliverables are transferred after agreed stages and payment unless otherwise stated.']]},ru:{title:'Публичная оферта',description:'Публичная оферта Dashkevich Studio на оказание услуг разработки и автоматизации.',label:'Документ',note:'Заготовка. Условия, цены, сроки, порядок оплаты и реквизиты нужно адаптировать под реальную модель работы.',sections:[['1. Предмет','Исполнитель оказывает услуги по разработке сайтов, веб-сервисов, интеграций, Telegram-ботов, автоматизации и AI-инструментов.'],['2. Порядок работы','Объём, сроки, стоимость и этапы согласуются в переписке, договоре, счёте или приложении.'],['3. Оплата','Оплата производится по согласованным условиям. До добавления онлайн-оплаты раздел используется как общий шаблон.'],['4. Результаты работ','Результаты передаются после выполнения согласованных этапов и оплаты, если иное не указано в договорённостях.']]},pl:{title:'Oferta publiczna',description:'Oferta publiczna Dashkevich Studio na usługi programistyczne i automatyzację.',label:'Dokument',note:'Wersja robocza. Warunki, ceny, terminy, płatność i dane firmy trzeba dopasować do rzeczywistego modelu współpracy.',sections:[['1. Zakres','Wykonawca realizuje strony, serwisy webowe, integracje, boty Telegram, automatyzację i narzędzia AI.'],['2. Proces','Zakres, terminy, cena i etapy są uzgadniane pisemnie, w umowie, fakturze lub załączniku.'],['3. Płatność','Płatność odbywa się na uzgodnionych warunkach. Ta sekcja pozostaje szablonem do czasu uruchomienia płatności online.'],['4. Rezultaty','Rezultaty są przekazywane po wykonaniu uzgodnionych etapów i płatności, o ile nie ustalono inaczej.']]}}[locale];
---
<BaseLayout title={c.title} description={c.description} path={localePath(locale,'/offer/')} locale={locale}><section class="legal-page"><p class="section-label">{c.label}</p><h1>{c.title}</h1><p class="legal-note">{c.note}</p>{c.sections.map(([title,text])=><><h2>{title}</h2><p>{text}</p></>)}<h2>5. Contact</h2><p><a href={`mailto:${site.email}`}>{site.email}</a> · <a href={site.phoneHref}>{site.phoneLabel}</a></p></section></BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';import {site} from '../data/site';import {localePath,type Locale} from '../i18n';
interface Props{locale?:Locale} const{locale='en'}=Astro.props;
const c={en:{title:'Privacy policy',description:'Dashkevich Studio privacy policy: what the website collects and how the data is used.',label:'Document',sections:[['1. Data we collect','The request form may collect a name, contact method, task description, selected service and attached materials.'],['2. How data is used','Data is used to answer the request, clarify the task, prepare a proposal and communicate about the project.'],['3. Storage and sharing','Data is not published or shared with third parties unless required to process the request or by law.'],['4. Cookies and analytics','The website may use cookies and analytics to understand traffic and improve the interface. Connected services should be listed here.'],['5. Contact',`For questions about personal data, email ${site.email}.`]]},ru:{title:'Политика конфиденциальности',description:'Политика конфиденциальности Dashkevich Studio: какие данные собираются через сайт и как они используются.',label:'Документ',sections:[['1. Какие данные собираются','Через форму заявки сайт может собирать имя, способ связи, описание задачи, выбранную услугу и прикреплённые материалы.'],['2. Зачем используются данные','Данные используются для ответа на заявку, уточнения задачи, подготовки предложения и дальнейшей коммуникации по проекту.'],['3. Хранение и передача','Данные не публикуются и не передаются третьим лицам без необходимости обработки заявки, кроме случаев, предусмотренных законом.'],['4. Cookie и аналитика','Сайт может использовать cookie и инструменты аналитики для понимания посещаемости и улучшения интерфейса.'],['5. Контакты',`По вопросам обработки данных можно написать на ${site.email}.`]]},pl:{title:'Polityka prywatności',description:'Polityka prywatności Dashkevich Studio: jakie dane zbiera strona i jak są wykorzystywane.',label:'Dokument',sections:[['1. Zbierane dane','Formularz może zbierać imię, sposób kontaktu, opis zadania, wybraną usługę i dołączone materiały.'],['2. Cel przetwarzania','Dane służą do odpowiedzi, doprecyzowania zadania, przygotowania oferty i komunikacji o projekcie.'],['3. Przechowywanie i udostępnianie','Dane nie są publikowane ani przekazywane osobom trzecim, chyba że wymaga tego obsługa zapytania lub prawo.'],['4. Cookie i analityka','Strona może używać plików cookie i analityki do badania ruchu i ulepszania interfejsu.'],['5. Kontakt',`W sprawie danych osobowych napisz na ${site.email}.`]]}}[locale];
---
<BaseLayout title={c.title} description={c.description} path={localePath(locale,'/privacy/')} locale={locale}><section class="legal-page"><p class="section-label">{c.label}</p><h1>{c.title}</h1>{c.sections.map(([title,text])=><><h2>{title}</h2><p>{text}</p></>)}</section></BaseLayout>

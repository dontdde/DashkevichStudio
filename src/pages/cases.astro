---
import BaseLayout from '../layouts/BaseLayout.astro';import CaseGrid from '../components/CaseGrid.astro';import {localePath,type Locale} from '../i18n';
interface Props{locale?:Locale} const{locale='en'}=Astro.props;
const copy={en:{title:'Web Development Case Studies',description:'Explore Dashkevich Studio web development cases with the client goal, design approach, responsive implementation, technology and delivered result.',label:'Cases',hero:'Dashkevich Studio web development cases',text:'Public projects with the business task, solution, visual logic, technical details and result.'},ru:{title:'Кейсы веб-разработки и автоматизации',description:'Кейсы Dashkevich Studio: задачи клиентов, дизайн, адаптивная разработка сайтов, технические решения и результаты реализованных проектов.',label:'Кейсы',hero:'Кейсы разработки сайтов Dashkevich Studio',text:'Реальные проекты, которые можно показать публично: задача, решение, визуальная логика, технические детали и результат.'},pl:{title:'Realizacje stron i automatyzacji',description:'Realizacje Dashkevich Studio: cele klientów, projektowanie, responsywne tworzenie stron, rozwiązania techniczne i rezultaty wdrożonych projektów.',label:'Realizacje',hero:'Realizacje stron internetowych Dashkevich Studio',text:'Publiczne projekty pokazujące zadanie biznesowe, rozwiązanie, logikę wizualną, szczegóły techniczne i rezultat.'}}[locale];
const schema={'@context':'https://schema.org','@type':'ItemList',name:copy.hero,itemListElement:[{'@type':'ListItem',position:1,name:'KITTENNIS.BY',url:`https://dashkevichstudio.by${localePath(locale,'/cases/')}#kittennis`}]};
---
<BaseLayout title={copy.title} description={copy.description} path={localePath(locale,'/cases/')} locale={locale} schema={schema}><section class="page-hero"><p class="section-label">{copy.label}</p><h1>{copy.hero}</h1><p>{copy.text}</p></section><section class="section"><CaseGrid locale={locale}/></section></BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';import {site} from '../data/site';import {localePath,type Locale} from '../i18n';
interface Props{locale?:Locale} const{locale='en'}=Astro.props;
const c={en:{title:'Self-employed details',description:'Dashkevich Studio contact and legal details.',label:'Details',heading:'Self-employed details',fields:['Service provider','Taxpayer reference','Email','Phone','Instagram']},ru:{title:'Реквизиты самозанятого',description:'Реквизиты самозанятого Dashkevich Studio для связи и юридической информации.',label:'Реквизиты',heading:'Реквизиты самозанятого',fields:['Исполнитель','ОНП','Email','Телефон','Instagram']},pl:{title:'Dane osoby samozatrudnionej',description:'Dane kontaktowe i prawne Dashkevich Studio.',label:'Dane',heading:'Dane osoby samozatrudnionej',fields:['Usługodawca','Numer podatnika','Email','Telefon','Instagram']}}[locale];
const values=['Дашкевич Илья Валерьевич, самозанятый','AE5184647',site.email,site.phoneLabel,site.instagramLabel];
---
<BaseLayout title={c.title} description={c.description} path={localePath(locale,'/requisites/')} locale={locale} robots="noindex,follow"><section class="legal-page"><p class="section-label">{c.label}</p><h1>{c.heading}</h1><div class="requisites-list">{c.fields.map((field,index)=><div><span>{field}</span><strong>{index===2?<a href={`mailto:${site.email}`}>{values[index]}</a>:index===3?<a href={site.phoneHref}>{values[index]}</a>:index===4?<a href={site.instagramUrl}>{values[index]}</a>:values[index]}</strong></div>)}</div></section></BaseLayout>

---
import { site } from '../data/site';
import InstagramIcon from './InstagramIcon.astro';
import TelegramIcon from './TelegramIcon.astro';

interface Props {
  title?: string;
  text?: string;
}

const {
  title = 'Готовы обсудить задачу?',
  text = 'Перейдите к основной форме заявки на главной странице. Там можно выбрать удобный способ связи, услугу и приложить материалы.'
} = Astro.props;
---

<section class="project-cta" aria-labelledby="project-cta-title">
  <div>
    <p class="section-label">Заявка</p>
    <h2 id="project-cta-title">{title}</h2>
    <p>{text}</p>
    <div class="cta-actions">
      <a class="button primary" href="/#request">Оставить заявку</a>
      <a class="button secondary" href="/cases/">Посмотреть кейсы</a>
    </div>
  </div>
  <div class="contact-stack" aria-label="Контакты">
    <div class="contact-rail">
      <a href={site.phoneHref}>
        <span>Телефон</span>
        <strong>{site.phoneLabel}</strong>
      </a>
      <a href={`mailto:${site.email}`}>
        <span>Email</span>
        <strong>{site.email}</strong>
      </a>
      <a href={site.instagramUrl}>
        <span>Instagram</span>
        <strong>{site.instagramLabel}</strong>
      </a>
    </div>
    <div class="contact-socials">
      <TelegramIcon className="contact-social-icon" />
      <InstagramIcon className="contact-social-icon" />
    </div>
  </div>
</section>

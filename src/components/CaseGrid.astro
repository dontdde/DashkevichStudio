const keys = ['salon', 'assistant', 'recruitment', 'kittennis'];
const cases = copy.cases.map((item, index) => ({ ...item, images: imageSets[keys[index]] }));
const compactCases = cases
  .filter((item) => caseIds.includes(item.id))
  .sort((a, b) => caseIds.indexOf(a.id) - caseIds.indexOf(b.id));
---

{compact ? (
  <div class="portfolio-compact-list">
    {compactCases.map((item) => (
      <article class="portfolio-compact-card">
        <a class="portfolio-compact-visual" href={`${localePath(locale, '/cases/')}#${item.id}`} aria-label={`${copy.open}: ${item.title}`}>
          <picture>
            {item.images[0].avif && <source srcset={item.images[0].avif} type="image/avif" />}
            <img src={item.images[0].src} alt={item.captions[0]} width={item.id === 'kittennis' ? '1440' : '2880'} height={item.id === 'kittennis' ? '1100' : '1800'} loading="lazy" />
          </picture>
          <span>{item.number}</span>
        </a>
        <div class="portfolio-compact-copy">
          <div class="portfolio-case-meta"><span>{item.category}</span></div>
          <h3>{item.title}</h3>
          <p>{item.summary}</p>
          <a class="portfolio-inline-link" href={`${localePath(locale, '/cases/')}#${item.id}`}>{copy.open}<span aria-hidden="true">↗</span></a>
        </div>
      </article>
    ))}
  </div>
) : (
  <>
    <div class="portfolio-case-grid">
      {cases.map((item, index) => (
        <article class={`portfolio-case-card portfolio-case-${item.id}`} style={`--case-order:${index}`}>
          <button type="button" data-case-open={item.id} aria-haspopup="dialog" aria-controls={`case-${item.id}`} aria-label={`${copy.open}: ${item.title}`}>
            <span class="portfolio-case-visual">
              <picture>
                {item.images[0].avif && <source srcset={item.images[0].avif} type="image/avif" />}
                <img src={item.images[0].src} alt={item.captions[0]} width={item.id === 'kittennis' ? '1440' : '2880'} height={item.id === 'kittennis' ? '1100' : '1800'} loading={index < 2 ? 'eager' : 'lazy'} />
              </picture>
              <span class="portfolio-case-number" aria-hidden="true">{item.number}</span>
            </span>
            <span class="portfolio-case-copy">
              <span class="portfolio-case-meta"><span>{item.category}</span><span>{item.metrics[0]}</span></span>
              <span class="portfolio-case-title" role="heading" aria-level="2">{item.title}</span>
              <span class="portfolio-case-summary">{item.summary}</span>
              <span class="portfolio-case-action">{copy.open}<span aria-hidden="true">↗</span></span>
            </span>
          </button>
        </article>
      ))}
      {copy.upcoming.map((item) => (
        <article class="portfolio-upcoming" aria-label={item}>
          <span>TO BE<br />CONTINUED...</span>
          <p>{item}</p>
        </article>
      ))}
    </div>

    {cases.map((item) => (
      <dialog class={`portfolio-case-dialog portfolio-dialog-${item.id}`} id={`case-${item.id}`} data-case-dialog={item.id} aria-labelledby={`case-title-${item.id}`}>
        <div class="portfolio-dialog-shell">
          <header class="portfolio-dialog-bar">
            <span><b>{item.number}</b>{item.category}</span>
            <button type="button" data-case-close title={copy.close} aria-label={copy.close}><span aria-hidden="true">×</span></button>
          </header>
          <div class="portfolio-dialog-content">
            <section class="portfolio-dialog-intro">
              <div>
                <h2 id={`case-title-${item.id}`}>{item.title}</h2>
                <p>{item.summary}</p>
              </div>
              <div class="portfolio-dialog-metrics">
                {item.metrics.map((metric) => <span>{metric}</span>)}
              </div>
            </section>

            <section class="portfolio-dialog-details" aria-label={copy.details}>
              {item.details.map(([title, text]) => (
                <article>
                  <h3>{title}</h3>
                  <p>{text}</p>
                </article>
              ))}
            </section>

            <section class="portfolio-dialog-gallery" aria-label={copy.gallery}>
              {item.images.map((image, imageIndex) => (
                <figure>
                  <picture>
                    {image.avif && <source srcset={image.avif} type="image/avif" />}
                    <img src={image.src} alt={item.captions[imageIndex]} width={item.id === 'kittennis' ? '1440' : '2880'} height={item.id === 'kittennis' ? '1100' : '1800'} loading="lazy" />
                  </picture>
                  <figcaption><span>{String(imageIndex + 1).padStart(2, '0')}</span>{item.captions[imageIndex]}</figcaption>
                </figure>
              ))}
            </section>
          </div>
        </div>
      </dialog>
    ))}

    <script>
      const caseButtons = document.querySelectorAll('[data-case-open]');
      const caseDialogs = document.querySelectorAll('[data-case-dialog]');
      let activeTrigger = null;

      const clearCaseHash = (caseId) => {
        if (window.location.hash !== `#${caseId}`) return;
        window.history.replaceState(null, '', `${window.location.pathname}${window.location.search}`);
      };

      const openCase = (caseId, updateHash = true) => {
        const dialog = document.querySelector(`[data-case-dialog="${caseId}"]`);
        if (!(dialog instanceof HTMLDialogElement)) return;

        caseDialogs.forEach((candidate) => {
          if (candidate instanceof HTMLDialogElement && candidate !== dialog && candidate.open) candidate.close();
        });

        if (!dialog.open) dialog.showModal();
        document.body.classList.add('case-dialog-open');
        if (updateHash) window.history.replaceState(null, '', `#${caseId}`);
      };

      caseButtons.forEach((button) => {
        button.addEventListener('click', () => {
          activeTrigger = button;
          openCase(button.getAttribute('data-case-open'));
        });
      });

      caseDialogs.forEach((dialog) => {
        if (!(dialog instanceof HTMLDialogElement)) return;
        const caseId = dialog.getAttribute('data-case-dialog');
        dialog.querySelector('[data-case-close]')?.addEventListener('click', () => dialog.close());
        dialog.addEventListener('click', (event) => {
          if (event.target === dialog) dialog.close();
        });
        dialog.addEventListener('close', () => {
          document.body.classList.remove('case-dialog-open');
          clearCaseHash(caseId);
          if (activeTrigger instanceof HTMLElement) activeTrigger.focus({ preventScroll: true });
        });
      });

      const openCaseFromHash = () => {
        const caseId = window.location.hash.slice(1);
        if (caseId) openCase(caseId, false);
      };

      openCaseFromHash();
      window.addEventListener('hashchange', openCaseFromHash);
    </script>
  </>
)}

---
import { localePath, type Locale } from '../i18n';

interface Props {
  compact?: boolean;
  locale?: Locale;
}

const { compact = false, locale = 'en' } = Astro.props;
const copy = {
  en: { category:'Sports club',direction:'End-to-end website',title:'KITTENNIS.BY website for a tennis club',summary:'A new club website with a strong homepage, KIT Division, match results, season archive, tournaments, partners and contacts.',result:'The club received a modern, mobile-friendly website with light and dark themes and optimized imagery.',highlights:['Light and dark theme','KIT Division and season archive','Latest match results','Mobile navigation','Optimized imagery'],details:[['Goal','Create a new visual and technical website while preserving the KIT Love to Win identity and the sections members use most.'],['What we built','Homepage, latest results, Division tables, season archive, tournaments, rules, partners and contacts.'],['Design','The visual system combines the tennis court, ball, racket and the club’s energetic sporting identity.'],['Technology','A lightweight static website built with HTML, CSS and JavaScript, with compressed image assets.']],gallery:['Light theme: homepage, navigation, Division entry point and recent results.','Dark theme: the same journey with an evening sports atmosphere.','Results section: matches, score and quick access to details.'],galleryLabel:'KITTENNIS.BY project screens',open:'Open KITTENNIS.BY case',tags:'What we built',upcoming:['New project in progress','Next case is being prepared']},
  ru: { category:'Спортивный клуб',direction:'Сайт под ключ',title:'Сайт KITTENNIS.BY для теннисного клуба',summary:'Создали новую версию сайта клуба интересного тенниса в Минске: первый экран, КИТ Дивизион, результаты матчей, архив сезонов, турниры, партнёры и контакты.',result:'Клуб получил современный сайт с выразительной спортивной подачей, мобильной адаптацией, светлой и тёмной темой и более лёгкими изображениями.',highlights:['Светлая и тёмная тема','КИТ Дивизион и архив сезонов','Последние результаты матчей','Мобильное бургер-меню','Оптимизация изображений'],details:[['Задача','Собрать новую визуальную и техническую версию сайта клуба, сохранив узнаваемость KIT Love to Win и важные разделы для участников.'],['Что сделали','Спроектировали главный экран, результаты, таблицы Дивизиона, архив сезонов, турниры, устав, партнёров и контакты.'],['Дизайн','Концепция построена вокруг теннисного корта, мяча, ракетки и клубной спортивной эстетики.'],['Техника','Лёгкий статический сайт на HTML, CSS и JavaScript с оптимизированными изображениями.']],gallery:['Светлая тема: первый экран, навигация, заявка в Дивизион и быстрые результаты.','Тёмная тема: тот же сценарий с вечерней спортивной атмосферой.','Раздел результатов: матчи, счёт и быстрый переход к деталям.'],galleryLabel:'Экраны проекта KITTENNIS.BY',open:'Открыть кейс KITTENNIS.BY',tags:'Что сделано',upcoming:['Новый проект в работе','Следующий кейс готовится']},
  pl: { category:'Klub sportowy',direction:'Kompleksowa strona',title:'Strona KITTENNIS.BY dla klubu tenisowego',summary:'Nowa strona klubu z mocnym ekranem głównym, KIT Division, wynikami meczów, archiwum sezonów, turniejami, partnerami i kontaktem.',result:'Klub otrzymał nowoczesną stronę mobilną z jasnym i ciemnym motywem oraz zoptymalizowanymi obrazami.',highlights:['Jasny i ciemny motyw','KIT Division i archiwum sezonów','Najnowsze wyniki meczów','Nawigacja mobilna','Optymalizacja obrazów'],details:[['Cel','Stworzyć nową wizualną i techniczną wersję strony, zachowując rozpoznawalność KIT Love to Win i ważne sekcje dla członków.'],['Co zrobiliśmy','Zaprojektowaliśmy stronę główną, wyniki, tabele Division, archiwum sezonów, turnieje, regulamin, partnerów i kontakt.'],['Design','System wizualny łączy kort, piłkę, rakietę i energiczną sportową tożsamość klubu.'],['Technologia','Lekka statyczna strona HTML, CSS i JavaScript ze zoptymalizowanymi obrazami.']],gallery:['Jasny motyw: strona główna, nawigacja, wejście do Division i wyniki.','Ciemny motyw: ten sam scenariusz w wieczornej atmosferze.','Sekcja wyników: mecze, wynik i szybki dostęp do szczegółów.'],galleryLabel:'Ekrany projektu KITTENNIS.BY',open:'Otwórz realizację KITTENNIS.BY',tags:'Co zrobiliśmy',upcoming:['Nowy projekt w realizacji','Kolejna realizacja jest przygotowywana']}
}[locale];
const previewAlt = {
  en: 'Responsive KITTENNIS.BY tennis club website on desktop and mobile',
  ru: 'Адаптивный сайт теннисного клуба KITTENNIS.BY на компьютере и телефоне',
  pl: 'Responsywna strona klubu tenisowego KITTENNIS.BY na komputerze i telefonie'
}[locale];
const galleryAlts = {
  en: ['KITTENNIS.BY homepage in light theme', 'KITTENNIS.BY homepage in dark theme', 'KITTENNIS.BY match results page'],
  ru: ['Главная страница KITTENNIS.BY в светлой теме', 'Главная страница KITTENNIS.BY в тёмной теме', 'Страница результатов матчей KITTENNIS.BY'],
  pl: ['Strona główna KITTENNIS.BY w jasnym motywie', 'Strona główna KITTENNIS.BY w ciemnym motywie', 'Strona wyników meczów KITTENNIS.BY']
}[locale];
---

<div class={`case-grid ${compact ? 'case-grid-compact' : ''}`}>
  <article class="case-card case-card-featured" id="kittennis">
      <a class="case-visual tennis-case-visual" href={`${localePath(locale, '/cases/')}#kittennis`} aria-label={copy.open}>
        <img src="/cases/kittennis/home-light-full.jpg" alt={previewAlt} width="1440" height="1100" loading={compact ? 'lazy' : 'eager'} fetchpriority={compact ? 'auto' : 'high'} />
        <div class="case-device">
          <img src="/cases/kittennis/home-light-mobile-full.png" alt="" loading="lazy" />
        </div>
      </a>
      <div class="case-body">
        <div class="case-meta">
          <span>{copy.category}</span>
          <span>{copy.direction}</span>
        </div>
        <h3>{copy.title}</h3>
        <p>{copy.summary}</p>
        {!compact && (
          <>
            <div class="case-tags" aria-label={copy.tags}>
              {copy.highlights.map((highlight) => <span>{highlight}</span>)}
            </div>
            <div class="case-details">
              {copy.details.map(([title, text]) => (
                <div>
                  <strong>{title}</strong>
                  <p>{text}</p>
                </div>
              ))}
            </div>
            <div class="case-gallery" aria-label={copy.galleryLabel}>
              <figure class="case-shot case-shot-wide">
                <img src="/cases/kittennis/home-light-full.jpg" alt={galleryAlts[0]} width="1440" height="1100" loading="lazy" />
                <figcaption>{copy.gallery[0]}</figcaption>
              </figure>
              <figure class="case-shot">
                <img src="/cases/kittennis/home-dark-full.jpg" alt={galleryAlts[1]} width="1440" height="1100" loading="lazy" />
                <figcaption>{copy.gallery[1]}</figcaption>
              </figure>
              <figure class="case-shot">
                <img src="/cases/kittennis/results-light-full.jpg" alt={galleryAlts[2]} width="1440" height="1100" loading="lazy" />
                <figcaption>{copy.gallery[2]}</figcaption>
              </figure>
            </div>
          </>
        )}
        <p class="case-result">{copy.result}</p>
      </div>
    </article>
  {copy.upcoming.map((item) => (
    <article class="case-card case-card-upcoming">
      <span>TO BE<br />CONTINUED...</span>
      <p>{item}</p>
    </article>
  ))}
</div>

---
import { localePath, type Locale } from '../i18n';

interface Props {
  compact?: boolean;
  locale?: Locale;
  caseIds?: string[];
}

interface CaseImage {
  src: string;
  avif?: string;
}

const { compact = false, locale = 'ru', caseIds = ['kittennis'] } = Astro.props;

const imageSets: Record<string, CaseImage[]> = {
  salon: [
    ['01-cover', '01-cover'],
    ['02-home-and-portfolio', '02-home-and-portfolio'],
    ['03-services-and-prices', '03-services-and-prices'],
    ['04-available-times', '04-available-times'],
    ['05-reminders-and-repeat-booking', '05-reminders-and-repeat-booking'],
    ['06-mobile-booking', '06-mobile-booking']
  ].map(([png, avif]) => ({ src: `/cases/salon/${png}.png`, avif: `/cases/salon/${avif}.avif` })),
  assistant: [
    ['01-cover', '01-cover'],
    ['02-client-dialog', '02-client-dialog'],
    ['03-client-request-summary', '03-client-request-summary'],
    ['04-meeting-scheduling', '04-meeting-scheduling'],
    ['05-manager-handoff', '05-manager-handoff'],
    ['06-sales-pipeline', '06-sales-pipeline']
  ].map(([png, avif]) => ({ src: `/cases/ai-assistant/${png}.png`, avif: `/cases/ai-assistant/${avif}.avif` })),
  recruitment: [
    ['01-cover', '01-cover'],
    ['02-all-sources', '02-all-sources'],
    ['03-ai-filtering', '03-ai-filtering'],
    ['04-telegram-candidate', '04-telegram-candidate'],
    ['05-ai-dialogue', '05-ai-dialogue'],
    ['06-manager-handoff', '06-manager-handoff']
  ].map(([png, avif]) => ({ src: `/cases/recruitment/${png}.png`, avif: `/cases/recruitment/${avif}.avif` })),
  kittennis: [
    { src: '/cases/kittennis/home-light-full.jpg' },
    { src: '/cases/kittennis/home-dark-full.jpg' },
    { src: '/cases/kittennis/results-light-full.jpg' }
  ]
};


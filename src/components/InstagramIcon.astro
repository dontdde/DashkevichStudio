---
import { site } from '../data/site';

interface Props {
  className?: string;
  label?: string;
}

const { className = '', label } = Astro.props;
---

<a class={`instagram-icon ${className}`} href={site.instagramUrl} aria-label="Перейти в Instagram">
  <svg viewBox="0 0 24 24" aria-hidden="true">
    <path
      d="M7.8 2h8.4A5.8 5.8 0 0 1 22 7.8v8.4a5.8 5.8 0 0 1-5.8 5.8H7.8A5.8 5.8 0 0 1 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2Zm0 2A3.8 3.8 0 0 0 4 7.8v8.4A3.8 3.8 0 0 0 7.8 20h8.4a3.8 3.8 0 0 0 3.8-3.8V7.8A3.8 3.8 0 0 0 16.2 4H7.8Zm8.7 2.05a1.35 1.35 0 1 1 0 2.7 1.35 1.35 0 0 1 0-2.7ZM12 7.15A4.85 4.85 0 1 1 12 16.85 4.85 4.85 0 0 1 12 7.15Zm0 2A2.85 2.85 0 1 0 12 14.85 2.85 2.85 0 0 0 12 9.15Z"
    />
  </svg>
  {label && <span>{label}</span>}
</a>

---
import { commonCopy, localePath, type Locale } from '../i18n';

interface Props { locale?: Locale; }
const { locale = 'en' } = Astro.props;
const copy = commonCopy[locale];

const apiBaseUrl = import.meta.env.PUBLIC_API_BASE_URL ?? '';
const contactValues = ['telegram', 'instagram', 'email', 'phone', 'custom'];
const serviceValues = ['website', 'tilda-wordpress', 'store', 'web-service', 'telegram-bot', 'crm-automation', 'ai-agent', 'integrations', 'custom'];
---

<form class="request-form" name="project-request" method="POST" data-api-url={`${apiBaseUrl}/api/v1/leads`}>
  <input type="hidden" name="source_page" data-source-page value="/" />
  <input type="hidden" name="utm_source" data-utm-source />
  <input type="hidden" name="utm_medium" data-utm-medium />
  <input type="hidden" name="utm_campaign" data-utm-campaign />
  <p class="hidden-field">
    <label>Company <input name="company" /></label>
  </p>
  <div class="form-head">
    <h2>{copy.formTitle}</h2>
    <p>{copy.formIntro}</p>
  </div>
  <label>
    {copy.name}
    <input name="name" autocomplete="name" placeholder={copy.namePlaceholder} maxlength="100" required />
  </label>
  <label>
    {copy.replyVia}
    <select name="contact_method" data-contact-method required>
      {contactValues.map((value, index) => <option value={value}>{copy.contactOptions[index]}</option>)}
    </select>
  </label>
  <label data-contact-field>
    <span data-contact-label>{copy.contactLabels[0]}</span>
    <input name="contact_value" data-contact-input placeholder={copy.contactPlaceholders[0]} maxlength="200" required />
  </label>
  <label>
    {copy.service}
    <select name="service" data-service-select required>
      <option value="">{copy.choose}</option>
      {serviceValues.map((value, index) => <option value={value}>{copy.serviceOptions[index]}</option>)}
    </select>
  </label>
  <label data-custom-service hidden>
    {copy.customService}
    <input name="custom_service" placeholder={copy.customServicePlaceholder} maxlength="200" />
  </label>
  <label>
    {copy.description}
    <textarea name="message" rows="5" placeholder={copy.descriptionPlaceholder} maxlength="3000" required></textarea>
  </label>
  <label>
    {copy.file}
    <input name="brief_file" type="file" accept=".pdf,.doc,.docx,.txt,.rtf,.png,.jpg,.jpeg,.webp,.zip" />
  </label>
  <label class="consent-check">
    <input name="personal_data_consent" type="checkbox" value="true" required />
    <span>
      {copy.consentBefore}
      <a href={localePath(locale, '/privacy/')}>{copy.consentLink}</a>.
    </span>
  </label>
  <p class="form-status" data-form-status role="status" aria-live="polite"></p>
  <button class="button primary" type="submit" data-submit-button>
    <span data-submit-label>{copy.submit}</span>
  </button>
</form>

<script define:vars={{ contactLabels: copy.contactLabels, contactPlaceholders: copy.contactPlaceholders, submitting: copy.submitting, submit: copy.submit, fileTooLarge: copy.fileTooLarge, sendError: copy.sendError, sendSuccess: copy.sendSuccess }}>
  const contactKeys = ['telegram', 'instagram', 'email', 'phone', 'custom'];
  const contactConfig = Object.fromEntries(contactKeys.map((key, index) => [key, {
    label: contactLabels[index],
    placeholder: contactPlaceholders[index]
  }]));

  document.querySelectorAll('.request-form').forEach((form) => {
    const methodSelect = form.querySelector('[data-contact-method]');
    const label = form.querySelector('[data-contact-label]');
    const input = form.querySelector('[data-contact-input]');
    const serviceSelect = form.querySelector('[data-service-select]');
    const customService = form.querySelector('[data-custom-service]');
    const customInput = customService?.querySelector('input');
    const status = form.querySelector('[data-form-status]');
    const submitButton = form.querySelector('[data-submit-button]');
    const submitLabel = form.querySelector('[data-submit-label]');
    const sourcePage = form.querySelector('[data-source-page]');

    const setStatus = (message, type = '') => {
      if (!status) return;
      status.textContent = message;
      status.dataset.type = type;
    };

    const setSubmitting = (isSubmitting) => {
      form.setAttribute('aria-busy', String(isSubmitting));
      if (submitButton) submitButton.disabled = isSubmitting;
      if (submitLabel) submitLabel.textContent = isSubmitting ? submitting : submit;
    };

    const syncContact = () => {
      const value = methodSelect?.value || 'telegram';
      const config = contactConfig[value] || contactConfig.telegram;
      if (label) label.textContent = config.label;
      if (input) input.placeholder = config.placeholder;
    };

    const syncService = () => {
      const isCustom = serviceSelect?.value === 'custom';
      if (customService) customService.hidden = !isCustom;
      if (customInput) customInput.required = isCustom;
    };

    methodSelect?.addEventListener('change', syncContact);
    serviceSelect?.addEventListener('change', syncService);
    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!form.reportValidity()) return;

      const fileInput = form.querySelector('input[type="file"]');
      const file = fileInput?.files?.[0];
      if (file && file.size > 10 * 1024 * 1024) {
        setStatus(fileTooLarge, 'error');
        fileInput.focus();
        return;
      }

      const params = new URLSearchParams(window.location.search);
      if (sourcePage) sourcePage.value = `${window.location.pathname}${window.location.search}`;
      ['source', 'medium', 'campaign'].forEach((key) => {
        const field = form.querySelector(`[data-utm-${key}]`);
        if (field) field.value = params.get(`utm_${key}`) || '';
      });

      setStatus('');
      setSubmitting(true);

      try {
        const requestId = globalThis.crypto?.randomUUID?.() ?? `${Date.now()}-${Math.random().toString(16).slice(2)}`;
        const response = await fetch(form.dataset.apiUrl, {
          method: 'POST',
          headers: { 'X-Request-Id': requestId },
          body: new FormData(form)
        });
        const payload = await response.json().catch(() => ({}));

        if (!response.ok) {
          throw new Error(payload.detail || payload.title || sendError);
        }

        form.reset();
        syncContact();
        syncService();
        setStatus(sendSuccess, 'success');
      } catch (error) {
        setStatus(
          error instanceof Error ? error.message : sendError,
          'error'
        );
      } finally {
        setSubmitting(false);
      }
    });
    if (window.location.hash === '#request') {
      form.classList.add('is-highlighted');
      window.setTimeout(() => form.classList.remove('is-highlighted'), 1200);
    }
    syncContact();
    syncService();
  });

  window.addEventListener('hashchange', () => {
    if (window.location.hash !== '#request') return;
    document.querySelectorAll('.request-form').forEach((form) => {
      form.classList.add('is-highlighted');
      window.setTimeout(() => form.classList.remove('is-highlighted'), 1200);
    });
  });
</script>

<div class="cookie-notice" data-cookie-notice>
  <p>
    Мы можем использовать cookie и аналитику, чтобы улучшать сайт. Продолжая пользоваться сайтом,
    вы соглашаетесь с <a href="/privacy/">политикой конфиденциальности</a>.
  </p>
  <button type="button" data-cookie-accept>Понятно</button>
</div>

<script>
  const notice = document.querySelector('[data-cookie-notice]');
  const button = document.querySelector('[data-cookie-accept]');

  if (notice && localStorage.getItem('dashkevich-cookie-ok') === 'true') {
    notice.setAttribute('hidden', '');
  }

  button?.addEventListener('click', () => {
    localStorage.setItem('dashkevich-cookie-ok', 'true');
    notice?.setAttribute('hidden', '');
  });
</script>

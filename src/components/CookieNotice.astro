---
import { commonCopy, localePath, type Locale } from '../i18n';

interface Props { locale?: Locale; }
const { locale = 'en' } = Astro.props;
const copy = commonCopy[locale];
---

<div class="cookie-notice" data-cookie-notice>
  <p>
    {copy.cookieBefore} <a href={localePath(locale, '/privacy/')}>{copy.consentLink}</a>.
  </p>
  <button type="button" data-cookie-accept>{copy.cookieAccept}</button>
</div>

<script>
  const notice = document.querySelector('[data-cookie-notice]');
  const button = document.querySelector('[data-cookie-accept]');

  if (notice && localStorage.getItem('dashkevich-cookie-ok') === 'true') {
    notice.setAttribute('hidden', '');
  }

  button?.addEventListener('click', () => {
    localStorage.setItem('dashkevich-cookie-ok', 'true');
    notice?.setAttribute('hidden', '');
  });
</script>
